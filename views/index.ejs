<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Trusted Draws</title>
  <link rel="stylesheet" href="/styles.css">
</head>
</head>
<body class="app">
  <div class="app-container">
    <div class="card">
      <h1>Trusted Draws</h1>
      <p>Create a new lottery or giveaway draw.</p>
      <form action="/draw" method="post">
        <label>Title
          <input type="text" name="title" required />
        </label>
        <label>Description
          <textarea name="description"></textarea>
        </label>
        <label>Organizer name
          <input type="text" name="organizerName" />
        </label>
        <label>Organizer email
          <input type="email" name="organizerEmail" />
        </label>
        <label>Entry format
          <select name="entryFormat">
            <option value="username">Username</option>
            <option value="email">Email</option>
            <option value="phone">Phone</option>
            <option value="custom">Custom ID</option>
            <option value="free-text">Free text</option>
          </select>
        </label>
        <div style="margin-top:12px">
          <button class="btn btn-primary" type="submit">Create Draw</button>
        </div>
      </form>
    </div>
  </div>
</body>
</html>
