<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Verify Entry</title>
</head>
  <link rel="stylesheet" href="/styles.css">
</head>
<body class="app">
  <div class="app-container">
    <div class="card">
      <h1>Verify entry for <%= draw.title %></h1>
      <form action="/verify/<%= draw.public_id %>" method="post">
        <label>Your original entry
          <input type="text" name="entryText" required />
        </label>
        <div style="margin-top:12px">
          <button class="btn btn-primary" type="submit">Verify</button>
        </div>
      </form>
      <% if (result) { %>
        <% if (result.winner) { %>
          <p>Congratulations! You won position #<%= result.position %>.</p>
        <% } else { %>
          <p>Not found in winners.</p>
        <% } %>
      <% } %>
    </div>
  </div>
</body>
</html>
